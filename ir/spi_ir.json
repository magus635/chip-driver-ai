    "registers": [
      {
        "name": "CR1",
        "full_name": "SPI control register 1",
        "offset": "0x00",
        "size_bits": 16,
        "reset_value": "0x0000",
        "access": "RW",
        "source": "RM0008 §25.5.1 p.714",
        "fields": [
          {
            "name": "BIDIMODE",
            "bits": "15",
            "access": "RW",
            "description": "Bidirectional data mode enable. 0: 2-line unidirectional, 1: 1-line bidirectional",
            "source": "RM0008 §25.5.1 p.714"
          },
          {
            "name": "BIDIOE",
            "bits": "14",
            "access": "RW",
            "description": "Output enable in bidirectional mode. 0: output disabled (receive-only), 1: output enabled (transmit-only)",
            "source": "RM0008 §25.5.1 p.714"
          },
          {
            "name": "CRCEN",
            "bits": "13",
            "access": "RW",
            "description": "Hardware CRC calculation enable. 0: disabled, 1: enabled. Note: should only be written when SPI is disabled (SPE=0)",
            "guard": "INV_SPI_004",
            "source": "RM0008 §25.5.1 p.715"
          },
          {
            "name": "CRCNEXT",
            "bits": "12",
            "access": "RW",
            "description": "CRC transfer next. 0: data phase, 1: next transfer is CRC",
            "source": "RM0008 §25.5.1 p.715"
          },
          {
            "name": "DFF",
            "bits": "11",
            "access": "RW",
            "description": "Data frame format. 0: 8-bit data frame, 1: 16-bit data frame. Note: should only be written when SPI is disabled (SPE=0)",
            "guard": "INV_SPI_004",
            "source": "RM0008 §25.5.1 p.715"
          },
          {
            "name": "RXONLY",
            "bits": "10",
            "access": "RW",
            "description": "Receive only. 0: Full duplex (transmit and receive), 1: Output disabled (receive-only mode)",
            "source": "RM0008 §25.5.1 p.715"
          },
          {
            "name": "SSM",
            "bits": "9",
            "access": "RW",
            "description": "Software slave management. 0: disabled (NSS pin controlled by hardware), 1: enabled (SSI bit value drives NSS)",
            "source": "RM0008 §25.5.1 p.715"
          },
          {
            "name": "SSI",
            "bits": "8",
            "access": "RW",
            "description": "Internal slave select. Only used when SSM=1. This bit value is forced onto NSS pin and IO value of NSS is ignored.",
            "source": "RM0008 §25.5.1 p.715"
          },
          {
            "name": "LSBFIRST",
            "bits": "7",
            "access": "RW",
            "description": "Frame format. 0: MSB transmitted first, 1: LSB transmitted first",
            "source": "RM0008 §25.5.1 p.715"
          },
          {
            "name": "SPE",
            "bits": "6",
            "access": "RW",
            "description": "SPI enable. 0: disabled, 1: enabled",
            "source": "RM0008 §25.5.1 p.715"
          },
          {
            "name": "BR",
            "bits": "5:3",
            "access": "RW",
            "description": "Baud rate control. 000=fPCLK/2, 001=fPCLK/4, 010=fPCLK/8, 011=fPCLK/16, 100=fPCLK/32, 101=fPCLK/64, 110=fPCLK/128, 111=fPCLK/256. Note: not used in I2S mode. Should not be changed when SPI is enabled.",
            "guard": "INV_SPI_002",
            "source": "RM0008 §25.5.1 p.715"
          },
          {
            "name": "MSTR",
            "bits": "2",
            "access": "RW",
            "description": "Master selection. 0: slave configuration, 1: master configuration. Note: not used in I2S mode; cleared automatically on MODF error",
            "source": "RM0008 §25.5.1 p.715"
          },
          {
            "name": "CPOL",
            "bits": "1",
            "access": "RW",
            "description": "Clock polarity. 0: CK=0 when idle, 1: CK=1 when idle. Not used in I2S mode. Should not be changed when SPI is enabled.",
            "guard": "INV_SPI_002",
            "source": "RM0008 §25.5.1 p.715"
          },
          {
            "name": "CPHA",
            "bits": "0",
            "access": "RW",
            "description": "Clock phase. 0: first clock transition is data capture, 1: second clock transition is data capture. Not used in I2S mode. Should not be changed when SPI is enabled.",
            "guard": "INV_SPI_002",
            "source": "RM0008 §25.5.1 p.715"
          }
        ]
      },
