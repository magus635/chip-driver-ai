          },
          {
            "name": "RXNE",
            "bits": "0",
            "access": "RO",
            "description": "Receive buffer not empty. 0: RX buffer empty, 1: RX buffer not empty",
            "source": "RM0008 §25.5.3 p.717"
          }
        ]
      },
