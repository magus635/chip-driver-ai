    "atomic_sequences": [
      {
        "id": "SEQ_OVR_CLEAR",
        "description": "Clear OVR (Overrun) flag. Requires two-step read sequence.",
        "steps": [
          {
            "op": "READ",
            "register": "DR",
            "note": "Step 1: Read the DR register"
          },
          {
            "op": "READ",
            "register": "SR",
            "note": "Step 2: Read the SR register to complete OVR clear"
          }
        ],
        "source": "RM0008 §25.3.10 p.693"
      },
      {
        "id": "SEQ_MODF_CLEAR",
        "description": "Clear MODF (Mode Fault) flag. Requires read-then-write sequence.",
        "steps": [
          {
            "op": "READ",
            "register": "SR",
            "note": "Step 1: Read SR register (while MODF=1)"
          },
          {
            "op": "WRITE",
            "register": "CR1",
            "value": "current_value",
            "note": "Step 2: Write CR1 with its current value (no actual change needed)"
          }
        ],
        "source": "RM0008 §25.3.10 p.693"
      },
      {
        "id": "SEQ_DISABLE_FULLDUPLEX",
        "description": "Correct full-duplex SPI disable sequence to avoid data loss.",
        "steps": [
          {
            "op": "WAIT",
            "register": "SR",
            "field": "RXNE",
            "value": 1,
