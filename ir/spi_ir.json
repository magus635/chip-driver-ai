          },
          {
            "name": "SSOE",
            "bits": "2",
            "access": "RW",
            "description": "SS output enable. 0: SS output disabled in master mode, 1: SS output enabled in master mode",
            "source": "RM0008 §25.5.2 p.716"
          },
          {
            "name": "TXDMAEN",
            "bits": "1",
            "access": "RW",
            "description": "TX buffer DMA enable. 0: disabled, 1: DMA request made when TXE=1",
            "source": "RM0008 §25.5.2 p.716"
          },
          {
            "name": "RXDMAEN",
            "bits": "0",
            "access": "RW",
            "description": "RX buffer DMA enable. 0: disabled, 1: DMA request made when RXNE=1",
            "source": "RM0008 §25.5.2 p.716"
          }
        ]
      },
