{
  "ir_version": "3.0",
  "peripheral": {
    "name": "DMA",
    "full_name": "Direct Memory Access Controller",
    "chip_family": "STM32F1",
    "chip_model": "STM32F103C8T6",
    "source_document": "RM0008 Rev 21",
    "instances": [
      {
        "name": "DMA1",
        "base_address": "0x40020000",
        "bus": "AHB",
        "channels": 7,
        "source": "RM0008 §13.4 p.275"
      }
    ],
    "registers": [
      {
        "name": "ISR",
        "full_name": "DMA interrupt status register",
        "offset": "0x00",
        "size_bits": 32,
        "reset_value": "0x00000000",
        "access": "R",
        "fields": [
          { "name": "TEIF1", "bits": "3", "description": "Channel 1 transfer error flag" },
          { "name": "HTIF1", "bits": "2", "description": "Channel 1 half transfer flag" },
          { "name": "TCIF1", "bits": "1", "description": "Channel 1 transfer complete flag" },
          { "name": "GIF1",  "bits": "0", "description": "Channel 1 global interrupt flag" },
          { "name": "TEIF2", "bits": "7" }, { "name": "HTIF2", "bits": "6" }, { "name": "TCIF2", "bits": "5" }, { "name": "GIF2", "bits": "4" },
          { "name": "TEIF3", "bits": "11" }, { "name": "HTIF3", "bits": "10" }, { "name": "TCIF3", "bits": "9" }, { "name": "GIF3", "bits": "8" },
          { "name": "TEIF4", "bits": "15" }, { "name": "HTIF4", "bits": "14" }, { "name": "TCIF4", "bits": "13" }, { "name": "GIF4", "bits": "12" },
          { "name": "TEIF5", "bits": "19" }, { "name": "HTIF5", "bits": "18" }, { "name": "TCIF5", "bits": "17" }, { "name": "GIF5", "bits": "16" },
          { "name": "TEIF6", "bits": "23" }, { "name": "HTIF6", "bits": "22" }, { "name": "TCIF6", "bits": "21" }, { "name": "GIF6", "bits": "20" },
          { "name": "TEIF7", "bits": "27" }, { "name": "HTIF7", "bits": "26" }, { "name": "TCIF7", "bits": "25" }, { "name": "GIF7", "bits": "24" }
        ]
      },
      {
        "name": "IFCR",
        "full_name": "DMA interrupt flag clear register",
        "offset": "0x04",
        "size_bits": 32,
        "reset_value": "0x00000000",
        "access": "W",
        "fields": [
          { "name": "CTEIF1", "bits": "3", "description": "Channel 1 transfer error clear" },
          { "name": "CHTIF1", "bits": "2", "description": "Channel 1 half transfer clear" },
          { "name": "CTCIF1", "bits": "1", "description": "Channel 1 transfer complete clear" },
          { "name": "CGIF1",  "bits": "0", "description": "Channel 1 global interrupt clear" }
        ]
      },
      {
        "name": "CCR",
        "full_name": "DMA channel configuration register",
        "offset": "0x08",
        "array_offset": "0x14",
        "array_size": 7,
        "fields": [
          { "name": "MEM2MEM", "bits": "14", "description": "Memory to memory mode" },
          { "name": "PL",      "bits": "13:12", "description": "Channel priority level. 00: Low, 01: Medium, 10: High, 11: Very high" },
          { "name": "MSIZE",   "bits": "11:10", "description": "Memory size. 00: 8-bits, 01: 16-bits, 10: 32-bits" },
          { "name": "PSIZE",   "bits": "9:8",   "description": "Peripheral size. 00: 8-bits, 01: 16-bits, 10: 32-bits" },
          { "name": "MINC",    "bits": "7",    "description": "Memory increment mode" },
          { "name": "PINC",    "bits": "6",    "description": "Peripheral increment mode" },
          { "name": "CIRC",    "bits": "5",    "description": "Circular mode" },
          { "name": "DIR",     "bits": "4",    "description": "Data transfer direction. 0: Peripheral to memory, 1: Memory to peripheral" },
          { "name": "TEIE",    "bits": "3",    "description": "Transfer error interrupt enable" },
          { "name": "HTIE",    "bits": "2",    "description": "Half transfer interrupt enable" },
          { "name": "TCIE",    "bits": "1",    "description": "Transfer complete interrupt enable" },
          { "name": "EN",      "bits": "0",    "description": "Channel enable" }
        ]
      },
      {
        "name": "CNDTR",
        "full_name": "DMA channel number of data register",
        "offset": "0x0C",
        "array_offset": "0x14",
        "array_size": 7,
        "bits": "15:0"
      },
      {
        "name": "CPAR",
        "full_name": "DMA channel peripheral address register",
        "offset": "0x10",
        "array_offset": "0x14",
        "array_size": 7
      },
      {
        "name": "CMAR",
        "full_name": "DMA channel memory address register",
        "offset": "0x14",
        "array_offset": "0x14",
        "array_size": 7
      }
    ],
    "invariants": [
      {
        "id": "INV_DMA_001",
        "expression": "CCR[x].EN == 0 => writable(CPAR[x], CMAR[x], CNDTR[x], CCR[x].DIR, CCR[x].PSIZE, CCR[x].MSIZE, CCR[x].PINC, CCR[x].MINC, CCR[x].CIRC, CCR[x].PL, CCR[x].MEM2MEM)",
        "description": "DMA channel must be disabled before configuring most parameters",
        "severity": "CRITICAL"
      }
    ],
    "init_sequence": [
      { "step": 1, "action": "Enable DMA clock in RCC_AHBENR" },
      { "step": 2, "action": "Ensure channel is disabled (CCR.EN=0)" },
      { "step": 3, "action": "Set peripheral address in CPAR" },
      { "step": 4, "action": "Set memory address in CMAR" },
      { "step": 5, "action": "Set number of data in CNDTR" },
      { "step": 6, "action": "Configure CCR: DIR, PSIZE, MSIZE, PINC, MINC, CIRC, PL" },
      { "step": 7, "action": "Enable interrupts if needed (TCIE, HTIE, TEIE)" },
      { "step": 8, "action": "Enable channel (CCR.EN=1)" }
    ]
  }
}
