# =============================================================
# project.env — 项目工具链配置
# 根据你的实际项目修改以下变量
# 使用前执行：source config/project.env
# =============================================================

# ── 芯片信息 ──────────────────────────────────────────────
export CHIP_FAMILY="STM32F4"           # 芯片系列
export CHIP_MODEL="STM32F407VGT6"      # 具体型号
export CPU_CORE="cortex-m4"            # ARM 核心
export FPU="fpv4-sp-d16"               # FPU 类型（无则留空）
export FLASH_SIZE=1024                 # Flash 大小 (KB)
export RAM_SIZE=192                    # SRAM 大小 (KB)
export SYSCLK_MHZ=168                  # 系统时钟 (MHz)
export APB1_MHZ=42                     # APB1 总线时钟 (MHz)
export APB2_MHZ=84                     # APB2 总线时钟 (MHz)

# ── 工具链路径 ────────────────────────────────────────────
export TOOLCHAIN_PREFIX="arm-none-eabi-"
export CC="${TOOLCHAIN_PREFIX}gcc"
export CXX="${TOOLCHAIN_PREFIX}g++"
export LD="${TOOLCHAIN_PREFIX}ld"
export OBJCOPY="${TOOLCHAIN_PREFIX}objcopy"
export NM="${TOOLCHAIN_PREFIX}nm"
export SIZE="${TOOLCHAIN_PREFIX}size"

# 验证工具链是否可用
if ! command -v $CC &> /dev/null; then
    echo "[ERROR] 工具链 $CC 未找到，请检查 PATH 或安装工具链"
    echo "        下载地址: https://developer.arm.com/downloads/-/arm-gnu-toolchain-downloads"
fi

# ── 编译选项 ──────────────────────────────────────────────
export CFLAGS="-mcpu=${CPU_CORE} -mthumb -mfpu=${FPU} -mfloat-abi=hard"
export CFLAGS="${CFLAGS} -Os -g3 -Wall -Wextra"
export CFLAGS="${CFLAGS} -fdata-sections -ffunction-sections"
export CFLAGS="${CFLAGS} -DCHIP_FAMILY=${CHIP_FAMILY}"

export LDFLAGS="-mcpu=${CPU_CORE} -mthumb -mfpu=${FPU} -mfloat-abi=hard"
export LDFLAGS="${LDFLAGS} -Wl,--gc-sections"
export LDFLAGS="${LDFLAGS} -specs=nano.specs -specs=nosys.specs"

# ── 链接脚本 ──────────────────────────────────────────────
export LINKER_SCRIPT="config/${CHIP_MODEL}.ld"

# ── 输出目录 ──────────────────────────────────────────────
export BUILD_DIR="build"
export TARGET_ELF="${BUILD_DIR}/firmware.elf"
export TARGET_BIN="${BUILD_DIR}/firmware.bin"
export TARGET_HEX="${BUILD_DIR}/firmware.hex"
export MAP_FILE="${BUILD_DIR}/output.map"

# ── 调试探针配置 ──────────────────────────────────────────
export DEBUG_PROBE="stlink"            # 可选：stlink / jlink / cmsis-dap / ftdi
export OPENOCD_CFG="config/openocd.cfg"
export FLASH_ADDR="0x08000000"         # Flash 起始地址
export DEBUG_PORT=3333                 # GDB server 端口

# ── 串口配置（用于调试输出采集）──────────────────────────
export SERIAL_PORT="/dev/ttyUSB0"      # Linux: /dev/ttyUSB0, macOS: /dev/cu.usbserial-xxx
export SERIAL_BAUD=115200
export SERIAL_CAPTURE_SECONDS=5        # 采集运行输出的秒数

# ── 项目源码 ──────────────────────────────────────────────
export SRC_DIR="src"
export INC_DIRS="src/include src/bsp/include src/drivers/Spi/include src/drivers/Can/include"

# ── AI 文档解析配置（V2.0 新增）─────────────────────────────
# CMSIS 官方头文件路径（可选，用于交叉验证）
# 若留空或 "auto"，系统会自动在 docs/ 和 config/ 下搜索
# 示例: "docs/stm32f4xx.h" 或 "/path/to/CMSIS/Device/ST/STM32F4xx/Include/stm32f407xx.h"
export CMSIS_HEADER_PATH=""

# 文档缓存开关（true/false）
# 启用后，若 docs/ 目录未变化则跳过重新解析
export DOC_CACHE_ENABLED="true"

# 默认审查严格度（strict/normal/relaxed）
# strict: 生产级，任何警告即失败
# normal: 开发级，仅关键错误失败
# relaxed: 原型级，仅致命错误失败
export REVIEW_LEVEL="strict"

# Errata 文档匹配模式（正则表达式）
# 用于识别 docs/ 目录下的勘误表文件
export ERRATA_PATTERN="(errata|ES[0-9]+|勘误)"

# JSON 输出验证（true/false）
# 启用后，doc-analyst 生成的 JSON 会通过 jq 验证语法
export JSON_VALIDATION_ENABLED="true"

# ── VSCode 集成 ───────────────────────────────────────────
# 以下变量供 .vscode/tasks.json 复用
export VSCODE_TOOLCHAIN_PATH=$(dirname $(which $CC))
