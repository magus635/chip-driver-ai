  "init_sequence": [
    {"step": 1, "action": "Enable RCC clock for SPI", "code": "RCC->APB2ENR |= RCC_APB2ENR_SPI1EN"},
    {"step": 2, "action": "Disable SPI (SPE=0) before configuration", "code": "SPIx->CR1 &= ~SPI_CR1_SPE"},
    {"step": 3, "action": "Configure baud rate BR[2:0]", "code": "CR1 |= (prescaler << 3)"},
    {"step": 4, "action": "Configure CPOL and CPHA", "code": "CR1 |= (cpol << 1) | cpha"},
    {"step": 5, "action": "Configure data frame format DFF", "code": "CR1 |= (dff << 11)"},
    {"step": 6, "action": "Configure frame format LSBFIRST", "code": "CR1 |= (lsbfirst << 7)"},
    {"step": 7, "action": "Configure NSS: SSM=1, SSI=1 for software NSS", "code": "CR1 |= SPI_CR1_SSM | SPI_CR1_SSI"},
    {"step": 8, "action": "Set master mode MSTR=1", "code": "CR1 |= SPI_CR1_MSTR"},
    {"step": 9, "action": "Enable SPI SPE=1", "code": "SPIx->CR1 |= SPI_CR1_SPE"}
  ],
  "timing_constraints": {
    "note": "SPE must be 0 when modifying CPOL, CPHA, DFF, BR bits",
    "bsy_check": "Wait for BSY=0 before disabling SPI",
    "baudrate_formula": "fSCK = fPCLK / 2^(BR+1), BR=0..7 gives /2../256"
  },
  "errors": [
    {
      "type": "Overrun",
      "flag": "SR.OVR",
      "description": "New data received while RXNE still set",
      "recovery": "Read DR then read SR to clear OVR flag"
    },
    {
      "type": "Mode Fault",
      "flag": "SR.MODF",
      "description": "NSS pulled low in master mode (hardware NSS)",
      "recovery": "Read SR then write CR1 to clear MODF, SPE and MSTR auto-cleared"
    },
    {
      "type": "CRC Error",
      "flag": "SR.CRCERR",
      "description": "CRC mismatch when CRCEN=1",
      "recovery": "Write 0 to CRCERR bit to clear"
    }
  ],
